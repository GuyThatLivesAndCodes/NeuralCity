{
  "name": "neuralcity",
  "version": "1.1.0",
  "description": "Build neural networks from the ground up. No frameworks, no fluff.",
  "main": "src/main/main.js",
  "author": "NeuralCity",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "version:bump": "node scripts/bump-version.js",
    "build": "node scripts/bump-version.js && electron-builder",
    "build:win": "node scripts/bump-version.js && electron-builder --win",
    "build:nobump": "electron-builder",
    "pack": "electron-builder --dir",
    "test": "node tests/run-tests.js"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {},
  "build": {
    "appId": "com.neuralcity.app",
    "productName": "NeuralCity",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "NeuralCity-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NeuralCity"
    }
  }
}
